# Configurações do Google OAuth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Configurações de Administrador
ADMIN_EMAIL=admin@tstools.com
ADMIN_PASSWORD=

# Outros Usuários
OPERACAO_USER=operacao@tstools.com
OPERACAO_PASSWORD=
GUEST_USER=guest@tstools.com
GUEST_PASSWORD=

# Configurações do NextAuth / Auth.js (ESSENCIAIS)
AUTH_SECRET= # Gerar com: openssl rand -base64 33
AUTH_URL=http://localhost:3000
TRUST_HOST=true

# Supabase (Obrigatório para o funcionamento da Biblioteca de Códigos)
# No Easypanel, estas variáveis DEVEM estar no momento do BUILD (em "Build Arguments")
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
SUPABASE_URL=
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=6543
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=
SUPABASE_DB_PASSWORD=

# Configurações do Sistema
NODE_ENV=production
PORT=3000
